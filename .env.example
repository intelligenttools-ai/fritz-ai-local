# Local Brain LLM endpoint. API key is optional for local endpoints that do not
# require authentication.
LLM_ENDPOINT=http://host.docker.internal:1234/v1
LLM_MODEL=local-model
LLM_API_KEY=

# Local Brain filesystem paths inside the container.
BRAIN_HOME=/data/brain
SKILLS_DIR=/app/skills

# Map host vault paths from ~/.brain/registry.yaml to container mount paths.
# Example macOS: /Users/YOUR_USER/Notes=/vaults/notes
BRAIN_PATH_MAP=/Users/YOUR_USER/Notes=/vaults/notes

# Scheduler is disabled and dry-run by default. Enable only after manual runs
# have been verified.
SCHEDULER_ENABLED=false
SCHEDULER_DRY_RUN=true
BRAIN_INTERVAL_MINUTES=30
CAPTURE_MAX_CHARS=4000
COMPILE_MAX_CAPTURES=1

# API token is optional. If you expose the API beyond localhost, set this or
# protect the service with a reverse proxy.
API_HOST=0.0.0.0
API_PORT=8765
API_TOKEN=
