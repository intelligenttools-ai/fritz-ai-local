# Local Brain LLM endpoint. Protocol selection is explicit and API key is
# optional for compatible endpoints that do not require authentication.
LLM_PROTOCOL=openai-compatible
LLM_ENDPOINT=http://host.docker.internal:11434/v1
LLM_MODEL=local-instruct-model
LLM_API_KEY=

# Embedding endpoint used by the container-owned vector index and search API.
# This is independent from the chat LLM endpoint.
EMBEDDING_ENABLED=false
EMBEDDING_ENDPOINT=http://host.docker.internal:11434/v1
EMBEDDING_MODEL=nomic-embed-text:latest
EMBEDDING_API_KEY=

# Local Brain filesystem paths inside the container.
BRAIN_HOME=/data/brain
SKILLS_DIR=/app/skills

# Map host vault paths from ~/.brain/registry.yaml to container mount paths.
# Example macOS: /Users/YOUR_USER/Notes=/vaults/notes
BRAIN_PATH_MAP=/Users/YOUR_USER/Notes=/vaults/notes

# Scheduler is disabled by default. Once explicitly enabled, it remains in
# dry-run simulation unless SCHEDULER_DRY_RUN=false is explicitly configured.
SCHEDULER_ENABLED=false
SCHEDULER_DRY_RUN=true
# Set true only when you have installed service autostart on this machine; status
# uses this to distinguish daemon processing from service/agent-triggered runs.
AUTOSTART_INSTALLED=false
BRAIN_INTERVAL_MINUTES=30
CAPTURE_MAX_CHARS=4000
# Safe default cap for automatic/default compile runs. Set to "all" only when
# intentionally compiling the full backlog.
COMPILE_MAX_CAPTURES=25

# External sync safety. First real external syncs such as git push are blocked
# unless this is explicitly enabled. Dry runs do not push.
ALLOW_FIRST_EXTERNAL_SYNC=false

# Human approval gate for high-impact operations. Leave empty to block operations
# that require approval. Large compile batches default to more than 10 proposals.
APPROVAL_TOKEN=
LARGE_BATCH_THRESHOLD=10

# API token is required for all /v1/* endpoints. Use a unique random value and
# export the same value through the env var named by registry api_token_env.
API_HOST=127.0.0.1
API_PORT=8765
API_TOKEN=replace-with-random-token
