# Canonical repo-root .env keys. This file is duplicated here for service-local
# reference; the Docker compose example reads ../../.env from the repo root.

LLM_ENDPOINT=http://host.docker.internal:1234/v1
LLM_MODEL=local-model
LLM_API_KEY=

BRAIN_HOME=/data/brain
SKILLS_DIR=/app/skills
BRAIN_PATH_MAP=/Users/YOUR_USER/Notes=/vaults/notes

SCHEDULER_ENABLED=false
SCHEDULER_DRY_RUN=true
BRAIN_INTERVAL_MINUTES=30
CAPTURE_MAX_CHARS=4000
COMPILE_MAX_CAPTURES=1

API_HOST=0.0.0.0
API_PORT=8765
API_TOKEN=
