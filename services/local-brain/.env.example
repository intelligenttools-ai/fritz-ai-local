# Canonical repo-root .env keys. This file is duplicated here for service-local
# reference; the Docker compose example maps only the keys it needs.

LLM_PROTOCOL=openai-compatible
LLM_ENDPOINT=http://host.docker.internal:1234/v1
LLM_MODEL=local-model
LLM_API_KEY=

EMBEDDING_ENABLED=false
EMBEDDING_ENDPOINT=http://host.docker.internal:1234/v1
EMBEDDING_MODEL=local-embedding-model
EMBEDDING_API_KEY=

BRAIN_HOME=/data/brain
SKILLS_DIR=/app/skills
BRAIN_PATH_MAP=/Users/YOUR_USER/Notes=/vaults/notes

SCHEDULER_ENABLED=false
SCHEDULER_DRY_RUN=true
AUTOSTART_INSTALLED=false
BRAIN_INTERVAL_MINUTES=30
CAPTURE_MAX_CHARS=4000
COMPILE_MAX_CAPTURES=25
ALLOW_FIRST_EXTERNAL_SYNC=false
APPROVAL_TOKEN=
LARGE_BATCH_THRESHOLD=10

API_HOST=127.0.0.1
API_PORT=8765
# Required for all /v1/* service endpoints. Use a unique random value.
API_TOKEN=replace-with-random-token
